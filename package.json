{
  "name": "aiengineelectron",
  "version": "1.0.107",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://github.com/MagicPotTeam/magicpot-open",
  "repository": {
    "type": "git",
    "url": "https://github.com/MagicPotTeam/magicpot-open.git"
  },
  "bugs": {
    "url": "https://github.com/MagicPotTeam/magicpot-open/issues"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "check:text-encoding": "node scripts/check-text-encoding.mjs",
    "check:i18n": "node scripts/check-i18n.mjs --strict-source",
    "check:i18n:report": "node scripts/check-i18n.mjs --scan-source",
    "check:i18n:update-baseline": "node scripts/check-i18n.mjs --update-baseline",
    "create:open-candidate": "node scripts/create-open-candidate.mjs",
    "check:open-candidate": "node scripts/create-open-candidate.mjs --verify",
    "format": "prettier --write . --config config/prettier/prettier.config.cjs --ignore-path config/prettier/prettierignore",
    "lint:renderer": "eslint --config config/eslint/eslint.config.mjs --cache --ext .ts,.tsx packages/app/src/renderer/src/",
    "lint:main": "eslint --config config/eslint/eslint.config.mjs --cache --ext .ts,.tsx packages/app/src/main/",
    "lint:preload": "eslint --config config/eslint/eslint.config.mjs --cache --ext .ts,.tsx packages/app/src/preload/",
    "lint:shared": "eslint --config config/eslint/eslint.config.mjs --cache --ext .ts,.tsx packages/app/src/shared/",
    "lint": "npm run check:text-encoding && npm run check:i18n && npm run lint:renderer && npm run lint:main && npm run lint:preload && npm run lint:shared",
    "lint:fix": "npm run check:text-encoding && npm run check:i18n && npm run lint:renderer -- --fix && npm run lint:main -- --fix && npm run lint:preload -- --fix && npm run lint:shared -- --fix",
    "typecheck:node": "tsc --noEmit -p config/tsconfig/tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p config/tsconfig/tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start:pure": "node scripts/run-electron-vite.mjs preview --mode pure",
    "start:embedded": "node scripts/run-electron-vite.mjs preview --mode embedded",
    "start": "npm run start:pure",
    "dev:pure": "chcp 65001 >nul && node scripts/run-electron-vite.mjs dev --mode pure",
    "dev:embedded": "cross-env-shell VITE_BUILD_MODE=embedded VITE_PACKAGE_MODE=embedded VITE_BUILD_MODE_NAME=Embedded VITE_MAGICPOT_AUTO_START_COMFYUI=true \"chcp 65001 >nul && node scripts/run-electron-vite.mjs dev --mode embedded\"",
    "dev": "cross-env VITE_MAGICPOT_AUTO_START_COMFYUI=true npm run dev:pure",
    "build:pure": "npm run typecheck && electron-vite build --config config/electron/electron.vite.config.ts --mode pure",
    "build:embedded": "npm run typecheck && electron-vite build --config config/electron/electron.vite.config.ts --mode embedded",
    "prepare:embedded-sources": "node scripts/prepare-embedded-comfyui-sources.mjs",
    "prepare:embedded-sources:dry-run": "node scripts/prepare-embedded-comfyui-sources.mjs --dry-run",
    "prepare:embedded-staging": "node scripts/prepare-embedded-staging.mjs",
    "prepare:embedded-python": "node scripts/prepare-embedded-python.mjs",
    "prepare:embedded-python:dry-run": "cross-env EMBEDDED_DRY_RUN=1 node scripts/prepare-embedded-python.mjs",
    "prepare:embedded": "npm run prepare:embedded-sources && npm run prepare:embedded-staging && npm run prepare:embedded-python",
    "postinstall": "electron-builder install-app-deps",
    "package:win": "electron-builder --config config/electron/electron-builder.config.js --win --x64",
    "package:mac": "electron-builder --config config/electron/electron-builder.config.js --mac --arm64",
    "package:linux": "electron-builder --config config/electron/electron-builder.config.js --linux",
    "package:all": "npm run package:win && npm run package:mac",
    "release:pure": "npm run build:pure && cross-env PACKAGE_MODE=pure npm run package:all",
    "release:embedded": "npm run release:embedded:win",
    "release:embedded:win": "npm run build:embedded && npm run prepare:embedded && cross-env PACKAGE_MODE=embedded npm run package:win",
    "release:update-submodules": "node scripts/release/update-embedded-submodules.mjs",
    "test:node": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.node.config.mjs",
    "test:core:coverage": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.core.config.mjs",
    "test:web:heavy:qapp-design": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/QuickAppPage/QAppDesignPanel/QAppDesignPanel.test.tsx",
    "test:web:heavy:custom-skill-manager": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/QuickAppPage/CustomSkillManagerPage.test.tsx",
    "test:web:heavy:panel-plugin": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/SettingsPage/PanelPlugin.test.tsx",
    "test:web:heavy:panel-llm": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/SettingsPage/PanelLLM.test.tsx",
    "test:web:heavy:chat-agent-skill": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/ChatPage/ChatPage.agentSkill.test.tsx",
    "test:web:stress:chat-memory": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/ChatPage/ChatPage.memoryStress.test.ts --pool=forks --maxWorkers=1",
    "test:web:heavy:image-edit-panel": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/components/ImageCanvas/components/ImageEditPanel/ImageEditPanel.test.tsx",
    "test:web:heavy:image-viewer": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/components/ImageCanvas/ImageViewer.test.tsx",
    "test:web:heavy:side-panel": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/components/SidePanel.test.tsx",
    "test:web:heavy:qapp-context": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/QuickAppPage/components/QAppContext.test.tsx",
    "test:web:light:1": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.light.config.mjs --shard=1/3",
    "test:web:light:2": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.light.config.mjs --shard=2/3",
    "test:web:light:3": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.light.config.mjs --shard=3/3",
    "test:web": "npm run test:web:heavy:qapp-design && npm run test:web:heavy:custom-skill-manager && npm run test:web:heavy:panel-plugin && npm run test:web:heavy:panel-llm && npm run test:web:heavy:chat-agent-skill && npm run test:web:heavy:image-edit-panel && npm run test:web:heavy:image-viewer && npm run test:web:heavy:side-panel && npm run test:web:heavy:qapp-context && npm run test:web:light:1 && npm run test:web:light:2 && npm run test:web:light:3",
    "test": "npm run test:node && npm run test:web",
    "test:smoke:startup": "cross-env NODE_OPTIONS=--max-old-space-size=6144 RUN_ELECTRON_STARTUP_SMOKE=1 vitest run --config config/vitest/vitest.node.smoke.config.mjs",
    "smoke:startup": "npm run build:pure && npm run test:smoke:startup",
    "benchmark:project-canvas:webgl:raw": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/projectCanvas/webglBenchmark.mjs",
    "benchmark:project-canvas:overlay:raw": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/projectCanvas/overlayBenchmark.mjs",
    "benchmark:project-canvas:video:raw": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/projectCanvas/videoBenchmark.mjs",
    "benchmark:project-canvas:real-board:raw": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/projectCanvas/realBoardBenchmark.mjs",
    "benchmark:project-canvas:real-board:import-1800:raw": "cross-env MAGICPOT_REAL_BOARD_MODE=import MAGICPOT_REAL_BOARD_IMAGE_COUNT=1800 MAGICPOT_REAL_BOARD_PRESSURE_DURATION_MS=30000 npm run benchmark:project-canvas:real-board:raw",
    "benchmark:project-canvas:real-board:mixed-3000:raw": "cross-env MAGICPOT_REAL_BOARD_MODE=mixed MAGICPOT_REAL_BOARD_IMAGE_COUNT=3000 MAGICPOT_REAL_BOARD_PRESSURE_DURATION_MS=30000 npm run benchmark:project-canvas:real-board:raw",
    "benchmark:project-canvas:webgl": "npm run build:pure && npm run benchmark:project-canvas:webgl:raw",
    "benchmark:project-canvas:overlay": "npm run build:pure && npm run benchmark:project-canvas:overlay:raw",
    "benchmark:project-canvas:video": "npm run build:pure && npm run benchmark:project-canvas:video:raw",
    "benchmark:project-canvas:real-board": "npm run build:pure && npm run benchmark:project-canvas:real-board:raw",
    "benchmark:project-canvas:real-board:import-1800": "npm run build:pure && npm run benchmark:project-canvas:real-board:import-1800:raw",
    "benchmark:project-canvas:real-board:mixed-3000": "npm run build:pure && npm run benchmark:project-canvas:real-board:mixed-3000:raw",
    "probe:project-canvas:dev-watch": "cross-env NODE_OPTIONS=--max-old-space-size=6144 node scripts/projectCanvas/devWatcherProbe.mjs",
    "qa:security-posture": "node scripts/qa-security-posture.mjs",
    "test:project-canvas:3d": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/ProjectCanvasPage/components/canvas3DConvergenceStress.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/components/canvas3DStageLoadQueue.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/components/canvas3DStageQuality.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/components/Canvas3DStage.cameraSync.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/components/Model3DViewerDialog.test.tsx packages/app/src/renderer/src/pages/ProjectCanvasPage/components/modelLoaders/sceneInstanceCloneCache.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/components/modelLoaders/sceneInstanceCloneCacheKey.test.ts --pool=forks --maxWorkers=1",
    "stress:project-canvas": "npm run qa:security-posture && npm run test:project-canvas:3d && cross-env NODE_OPTIONS=--max-old-space-size=6144 vitest run --config config/vitest/vitest.web.config.mjs packages/app/src/renderer/src/pages/ProjectCanvasPage/projectCanvasRenderBoundary.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/canvasViewerPlaybackUtils.test.ts packages/app/src/renderer/src/pages/ProjectCanvasPage/ProjectCanvasPageVisualOverlays.test.tsx packages/app/src/renderer/src/pages/ProjectCanvasPage/ProjectCanvasPageStageScene.test.tsx packages/app/src/renderer/src/pages/ProjectCanvasPage/components/ProjectCanvasWebGLImageLayer.test.tsx packages/app/src/renderer/src/pages/ProjectCanvasPage/components/VideoOverlay.test.tsx --pool=forks --maxWorkers=1 && npm run build:pure && npm run benchmark:project-canvas:webgl:raw && npm run benchmark:project-canvas:overlay:raw && npm run benchmark:project-canvas:video:raw && cross-env MAGICPOT_REAL_BOARD_MODE=seeded-hires MAGICPOT_REAL_BOARD_IMAGE_COUNT=300 MAGICPOT_REAL_BOARD_PRESSURE_DURATION_MS=15000 npm run benchmark:project-canvas:real-board:raw && npm run probe:project-canvas:dev-watch",
    "smoke:hunyuan3d:live": "cross-env HUNYUAN3D_SMOKE_MODE=rapid npx tsx --tsconfig config/tsconfig/tsconfig.node.json scripts/hunyuan3d/liveSmoke.ts",
    "smoke:hunyuan3d:live:pro": "cross-env HUNYUAN3D_SMOKE_MODE=pro npx tsx --tsconfig config/tsconfig/tsconfig.node.json scripts/hunyuan3d/liveSmoke.ts",
    "smoke:hunyuan3d:live:all": "cross-env HUNYUAN3D_SMOKE_MODE=all npx tsx --tsconfig config/tsconfig/tsconfig.node.json scripts/hunyuan3d/liveSmoke.ts",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*": [
      "node scripts/check-text-encoding.mjs"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --config config/eslint/eslint.config.mjs --fix --quiet",
      "prettier --write --config config/prettier/prettier.config.cjs --ignore-path config/prettier/prettierignore"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mui/icons-material": "^7.3.1",
    "@mui/lab": "^7.0.0-beta.16",
    "@mui/material": "^7.3.1",
    "@mui/styled-engine-sc": "^7.3.1",
